# Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy...

# Google OAuth 2.0 credentials
# Create at: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Application type: Web application
# Authorized redirect URIs: http://localhost:3000/auth/callback (local) and your production URL
GOOGLE_OAUTH_CLIENT_ID=123456789-abc.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...

# Optional: set this explicitly in production if the redirect URI auto-detection fails
# e.g. REDIRECT_URI=https://your-app.up.railway.app/auth/callback
REDIRECT_URI=

# Random secret for signing session cookies — use any long random string
SESSION_SECRET=change-me-to-a-long-random-string

# Server port (Railway sets this automatically; use 3000 for local dev)
PORT=3000
