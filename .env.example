# Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy...

# Google Service Account JSON, base64-encoded (no newlines)
# PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json"))
# Mac/Linux:  base64 -i service-account.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_KEY=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50...

# The Google Calendar to write events to
# Use "primary" or a specific calendar ID like abc123@group.calendar.google.com
GOOGLE_CALENDAR_ID=primary

# Server port (Railway sets this automatically; use 3000 for local dev)
PORT=3000
